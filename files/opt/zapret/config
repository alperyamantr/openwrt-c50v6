WS_USER="daemon"
FWTYPE=nftables
POSTNAT=1

SET_MAXELEM=8192
IPSET_OPT="hashsize 2048 maxelem 8192"

MODE_FILTER=none

NFQWS_ENABLE=1

# C50 optimize: TTL=4 ile 2 fake yeterli
NFQWS_TCP_PKT_OUT="2"
NFQWS_TCP_PKT_IN="1"

# C50 optimize: QUIC için 6 fake (handshake kalabalık)
NFQWS_UDP_PKT_OUT="6"
NFQWS_UDP_PKT_IN="1"

DISABLE_IPV4=0
DISABLE_IPV6=1

FLOWOFFLOAD=software
FILTER_TTL_EXPIRED_ICMP=1

DAEMON_LOG_ENABLE=0