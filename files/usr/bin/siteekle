#!/bin/sh
if [ -z "$1" ]; then
    echo "Kullanım: siteekle domain.com"
    exit 1
fi

DOMAIN=$(echo "$1" | tr 'A-Z' 'a-z' | xargs)
BANNED_FILE="/etc/dnsmasq.d/banned.conf"

mkdir -p /etc/dnsmasq.d
touch "$BANNED_FILE"

# Mükerrer kontrolü
if grep -Fq "address=/$DOMAIN/0.0.0.0" "$BANNED_FILE" 2>/dev/null; then
    echo "[-] $DOMAIN zaten engelli listesinde var bro!"
    exit 0
fi

# Marker yoksa oluştur
if ! grep -Fq "# ==SITEEKLE-BITIS==" "$BANNED_FILE" 2>/dev/null; then
    # USOM marker'dan önce siteekle marker'ı ekle
    if grep -Fq "# ==USOM-BASLANGIC==" "$BANNED_FILE" 2>/dev/null; then
        sed -i "/# ==USOM-BASLANGIC==/i # ==SITEEKLE-BASLANGIC==\n# ==SITEEKLE-BITIS==" "$BANNED_FILE"
    else
        # Hiç marker yoksa dosya sonuna ekle
        echo -e "# ==SITEEKLE-BASLANGIC==\n# ==SITEEKLE-BITIS==" >> "$BANNED_FILE"
    fi
fi

# Yeni domaini SITEEKLE-BITIS marker'dan önce ekle
sed -i "/# ==SITEEKLE-BITIS==/i address=/$DOMAIN/0.0.0.0" "$BANNED_FILE"

/etc/init.d/dnsmasq restart >/dev/null 2>&1

TIMEOUT=0
while ! nslookup localhost 127.0.0.1 >/dev/null 2>&1; do
    sleep 1
    TIMEOUT=$((TIMEOUT + 1))
    if [ $TIMEOUT -gt 15 ]; then
        echo "[!] Dnsmasq başlatılırken zaman aşımı oluştu."
        exit 1
    fi
done

echo "[+] $DOMAIN başarıyla banned.conf dosyasına eklendi."