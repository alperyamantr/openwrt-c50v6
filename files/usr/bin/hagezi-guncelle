#!/bin/sh

URL="https://raw.githubusercontent.com/hagezi/dns-blocklists/main/dnsmasq/pro.mini.txt"
TARGET="/tmp/hagezi_multi.conf"
TEMP_FILE="/tmp/hagezi_download.tmp"

logger -t hagezi "Blocklist update started..."

if wget -qO "$TEMP_FILE" "$URL"; then
    if [ -s "$TEMP_FILE" ]; then
        mv "$TEMP_FILE" "$TARGET"
        /etc/init.d/dnsmasq reload
        logger -t hagezi "Blocklist updated successfully."
        echo "[+] Blocklist updated successfully!"
        exit 0
    else
        logger -t hagezi "Downloaded file is empty."
        echo "[-] Error: Downloaded file is empty."
    fi
else
    logger -t hagezi "Download failed."
    echo "[-] Error: Download failed."
fi

rm -f "$TEMP_FILE"
touch "$TARGET"
exit 1
