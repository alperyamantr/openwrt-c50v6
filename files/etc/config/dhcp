
config dnsmasq
	option domainneeded '1'
	option filterwin2k '1'
	option localise_queries '1'
	option rebind_protection '0'
	option local '/lan/'
	option domain 'lan'
	option nonegcache '1'
	option cachesize '1250'
	option authoritative '1'
	option readethers '1'
	option leasefile '/tmp/dhcp.leases'
	option localservice '1'
	option ednspacket_max '1232'
	option filter_aaaa '1'
	option noresolv '1'
	list server '94.140.14.14'
	list server '94.140.15.15'
	option allservers '1'
	option min_cache_ttl '300'
	option max_cache_ttl '3600'
	option quietdhcp '1'

config dhcp 'lan'
	option interface 'lan'
	option start '100'
	option limit '150'
	option leasetime '48h'
	option ra_manage '0'

config dhcp 'wan'
	option interface 'wan'
	option ignore '1'
